<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ elevage.nom }} — {{ elevage.race }}{% if elevage.departement %} | {{ elevage.departement }}{% endif %}</title>
  <meta name="description" content="Élevage {{ elevage.race }} — {{ elevage.nom }}{% if elevage.departement %} — {{ elevage.departement }}{% endif %}">
  <meta property="og:title" content="{{ elevage.nom }} — {{ elevage.race }}">
  <meta property="og:description" content="Élevage {{ elevage.race }}">
  <meta property="og:image" content="{% if photos.hero %}{{ photos.hero }}{% endif %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #1B3A4B; --accent: #D4622A; --bg: #F7F4EF; --cream: #EDE4D3;
      --text: #1B2D38; --muted: #7A8E99;
      --serif: 'Playfair Display', serif; --sans: 'Inter', sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: var(--bg); color: var(--text); }
    img { width: 100%; height: 100%; object-fit: cover; display: block; }
    a { color: inherit; text-decoration: none; }
    .container { max-width: 1200px; margin: auto; padding: 0 24px; }
    .reveal { opacity: 0; transform: translateY(30px); transition: all .8s ease; }
    .reveal.on { opacity: 1; transform: none; }

    nav { position: fixed; top: 0; width: 100%; z-index: 100; background: rgba(247,244,239,.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(27,45,56,.08); }
    nav .container { display: flex; justify-content: space-between; align-items: center; height: 68px; }
    .nav-logo { font-family: var(--serif); font-size: 1.1rem; color: var(--primary); }
    .nav-links a { font-size: .85rem; font-weight: 500; color: var(--muted); margin-left: 2rem; }
    .nav-links a:hover { color: var(--primary); }

    .hero { min-height: 100vh; display: flex; align-items: center; padding-top: 68px; background: linear-gradient(135deg, var(--cream), var(--bg), var(--cream)); }
    .hero .container { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    .hero-text h1 { font-family: var(--serif); font-size: 3rem; line-height: 1.1; color: var(--primary); margin-bottom: 8px; }
    .race-tag { display: inline-block; background: var(--primary); color: white; padding: 4px 14px; border-radius: 20px; font-size: .75rem; font-weight: 600; margin-bottom: 20px; }
    .hero-text p { color: var(--muted); line-height: 1.7; margin-bottom: 24px; }
    .hero-img { border-radius: 12px; overflow: hidden; box-shadow: 0 20px 60px rgba(27,58,75,.15); }
    .hero-img img { height: 500px; }

    section { padding: 80px 0; }
    .section-title { font-family: var(--serif); font-size: 2.2rem; color: var(--primary); margin-bottom: 32px; }
    .alt-bg { background: var(--cream); }

    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
    .about-text p { color: var(--muted); line-height: 1.8; margin-bottom: 12px; }

    .race-content { max-width: 700px; margin: auto; text-align: center; }
    .race-content p { color: var(--muted); line-height: 1.8; }
    .quote { font-family: var(--serif); font-size: 1.3rem; font-style: italic; color: var(--primary); padding: 24px 0; }

    .gal-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; }
    .gal-grid img { height: 250px; border-radius: 8px; }

    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
    .contact-phone { font-size: 1.5rem; font-weight: 700; color: var(--primary); margin: 16px 0; }

    footer { background: var(--primary); color: rgba(255,255,255,.6); padding: 32px 0; text-align: center; }
    footer p { font-size: .85rem; }
    footer a { color: var(--cream); text-decoration: underline; }

    @media(max-width:768px){
      .hero .container, .about-grid, .contact-grid { grid-template-columns: 1fr; }
      .hero-text h1 { font-size: 2rem; }
      .gal-grid { grid-template-columns: 1fr 1fr; }
      .nav-links { display: none; }
    }
  </style>
</head>
<body>
<nav>
  <div class="container">
    <span class="nav-logo">{{ elevage.nom }}</span>
    <div class="nav-links">
      <a href="#about">À propos</a>
      <a href="#race">La race</a>
      {% if photos.galerie %}<a href="#galery">Galerie</a>{% endif %}
      <a href="#contact">Contact</a>
    </div>
  </div>
</nav>

<section class="hero">
  <div class="container">
    <div class="hero-text">
      <span class="race-tag">{{ elevage.race }}</span>
      <h1>{{ elevage.nom }}</h1>
      <p>{% if elevage.departement %}{{ elevage.departement }}{% endif %}</p>
      <p>Élevage {{ elevage.race }} — {{ elevage.nom }}</p>
      <a href="#contact" class="btn" style="display:inline-block;padding:12px 28px;background:var(--primary);color:white;border-radius:6px;font-weight:600;">Me contacter</a>
    </div>
    <div class="hero-img reveal">
      <img src="{% if photos.hero %}{{ photos.hero }}{% else %}https://images.pexels.com/photos/1108099/pexels-photo-1108099.jpeg{% endif %}" alt="{{ elevage.nom }}">
    </div>
  </div>
</section>

{% if elevage.description_about %}
<section id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-text reveal">
        <h2 class="section-title">À propos</h2>
        {% for line in elevage.description_about.split('\n') %}
          {% if line.strip() %}<p>{{ line.strip() }}</p>{% endif %}
        {% endfor %}
      </div>
      {% if photos.about_1 %}
      <div class="reveal"><img src="{{ photos.about_1 }}" alt="{{ elevage.nom }}" style="height:450px;border-radius:12px;"></div>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

<section id="race" class="alt-bg">
  <div class="container">
    <div class="race-content reveal">
      <h2 class="section-title">Le {{ elevage.race }}</h2>
      <p>Le {{ elevage.race }} est une race de chien reconnue pour ses qualités exceptionnelles. Chaque chien est le fruit d'une sélection rigoureuse pour préserver les meilleures caractéristiques de la race.</p>
      <p style="margin-top:16px;">Pour en savoir plus sur cette magnifique race et découvrir ses particularités, n'hésitez pas à nous contacter.</p>
    </div>
  </div>
</section>

{% if photos.galerie %}
<section id="galery">
  <div class="container">
    <div style="text-align:center;"><h2 class="section-title">Galerie</h2></div>
    <div class="gal-grid">
      {% for url in photos.galerie %}
      <img src="{{ url }}" alt="{{ elevage.race }}" class="reveal" loading="lazy">
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<section id="contact" class="alt-bg">
  <div class="container">
    <div class="contact-grid">
      <div class="reveal">
        <h2 class="section-title">Contact</h2>
        <p>N'hésitez pas à nous contacter pour toute information.</p>
        <div class="contact-phone">📞 {{ elevage.telephone }}</div>
        <p style="margin-top:12px;">{{ elevage.departement or "France" }}</p>
        {% if elevage.siren %}<p style="margin-top:8px;color:var(--muted);font-size:.85rem;">SIREN {{ elevage.siren }}</p>{% endif %}
      </div>
      <div class="reveal" style="background:white;padding:32px;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,.04);">
        <h3 style="font-family:var(--serif);font-size:1.3rem;margin-bottom:16px;">{{ elevage.nom }}</h3>
        <p style="color:var(--muted);margin-bottom:20px;">Élevage {{ elevage.race }}.</p>
        <a href="tel:{{ elevage.telephone }}" style="display:block;text-align:center;padding:12px;background:var(--primary);color:white;border-radius:6px;font-weight:600;">📞 {{ elevage.telephone }}</a>
      </div>
    </div>
  </div>
</section>

<footer>
  <p>© 2026 — {{ elevage.nom }} — {{ elevage.race }}</p>
  {% if elevage.departement %}<p style="margin-top:4px;">{{ elevage.departement }}</p>{% endif %}
</footer>

<script>
  const observer = new IntersectionObserver(e => { e.forEach(e => { if(e.isIntersecting) e.target.classList.add('on'); }); }, { threshold: .15 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
</body>
</html>
