<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ elevage.nom }} — Élevage {{ elevage.race }}{% if elevage.departement %} | {{ elevage.departement }}{% endif %}</title>
  <meta name="description" content="{% if elevage.description_seo %}{{ elevage.description_seo }}{% else %}Élevage {{ elevage.race }} — {{ elevage.nom }}{% if elevage.departement %} — {{ elevage.departement }}{% endif %}{% endif %}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="">
  <meta property="og:title" content="{{ elevage.nom }} — {{ elevage.race }}{% if elevage.departement %}, {{ elevage.departement }}{% endif %}">
  <meta property="og:description" content="{% if elevage.description_seo %}{{ elevage.description_seo }}{% else %}Élevage {{ elevage.race }}{% endif %}">
  <meta property="og:image" content="{% if photos.og %}{{ photos.og }}{% elif photos.hero %}{{ photos.hero }}{% endif %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Raleway:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap" rel="stylesheet">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": ["LocalBusiness", "AnimalShelter"],
        "name": "{{ elevage.nom }}",
        "description": "Élevage de {{ elevage.race }}{% if elevage.departement %} en {{ elevage.departement }}{% endif %}",
        "address": {
          "@type": "PostalAddress",
          "addressRegion": "{{ elevage.departement }}",
          "postalCode": "{{ elevage.code_postal }}",
          "addressCountry": "FR"
        },
        "telephone": "{{ elevage.telephone }}"
      }
    ]
  }
  </script>
  <style>
    :root {
      --slt: {{ couleurs.primaire }}; --sky: {{ couleurs.primaire }}88; --snd: {{ couleurs.fond }}; --emb: {{ couleurs.accent }}; --bg: {{ couleurs.fond }}; --crm: {{ couleurs.fond }}dd;
      --txt: #1B2D38; --muted: #7A8E99; --FD: 'Cinzel', serif; --FN: 'Raleway', sans-serif; --nav: 68px; --r: 10px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--FN); background: var(--bg); color: var(--txt); overflow-x: hidden; }
    img { display: block; width: 100%; height: 100%; object-fit: cover; }
    a { color: inherit; text-decoration: none; }
    ul { list-style: none; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; }
    .reveal { opacity: 0; transform: translateY(24px); transition: opacity .75s ease, transform .75s ease; }
    .reveal.on { opacity: 1; transform: none; }
    .btn { display: inline-block; padding: .8rem 2.2rem; border-radius: 50px; font-weight: 600; font-size: .9rem; transition: all .25s; border: none; cursor: pointer; }
    .btn_primary { background: var(--slt); color: white; }
    .btn_primary:hover { background: var(--sky); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(27,58,75,.25); }
    .ghost_btn { background: transparent; color: var(--slt); border: 2px solid var(--slt); }
    .ghost_btn:hover { background: var(--slt); color: white; }

    nav { position: fixed; top: 0; width: 100%; z-index: 1000; background: rgba(247,244,239,.95); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(27,45,56,.08); }
    nav .container { display: flex; justify-content: space-between; align-items: center; height: var(--nav); }
    .nav_logo { font-family: var(--FD); font-size: 1.2rem; color: var(--slt); }
    .nav_rub a { font-size: .85rem; font-weight: 600; color: var(--muted); margin-left: 2.5rem; transition: color .3s; }
    .nav_rub a:hover { color: var(--slt); }
    .container { max-width: 1200px; margin: auto; padding: 0 24px; }

    .hero { min-height: 100vh; display: flex; align-items: center; padding-top: var(--nav); background: linear-gradient(135deg, var(--crm) 0%, var(--bg) 50%, var(--snd) 100%); }
    .hero .container { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    .hero_txt h1 { font-family: var(--FD); font-size: 3.2rem; line-height: 1.1; color: var(--slt); margin-bottom: 8px; }
    .race_tag { display: inline-block; background: var(--slt); color: white; padding: 4px 14px; border-radius: 20px; font-size: .75rem; font-weight: 600; letter-spacing: .5px; margin-bottom: 20px; }
    .hero_txt p { font-size: 1rem; line-height: 1.7; color: var(--muted); margin-bottom: 28px; }
    .hero_txt .loc { font-size: .9rem; color: var(--muted); margin-bottom: 20px; }
    .hero_img { border-radius: var(--r); overflow: hidden; box-shadow: 0 20px 60px rgba(27,58,75,.15); }
    .hero_img img { height: 550px; }
    .hero_btns { display: flex; gap: 12px; flex-wrap: wrap; }
    .hero_stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-top: 40px; padding-top: 28px; border-top: 1px solid rgba(27,58,75,.1); }
    .hero_stats .val { font-family: var(--FD); font-size: 1.6rem; color: var(--slt); }
    .hero_stats .lbl { font-size: .8rem; color: var(--muted); margin-top: 2px; }

    section { padding: 100px 0; }
    .sec_title { font-family: var(--FD); font-size: 2.4rem; color: var(--slt); margin-bottom: 12px; }
    .sec_sub { font-size: 1rem; color: var(--muted); max-width: 560px; margin-bottom: 48px; }

    .about_g { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    .about_g p { font-size: .95rem; line-height: 1.8; color: var(--muted); margin-bottom: 14px; }
    .about_img { border-radius: var(--r); overflow: hidden; box-shadow: 0 12px 40px rgba(27,58,75,.08); }

    .alt_bg { background: var(--crm); }

    .race_c { max-width: 720px; margin: 0 auto; text-align: center; }
    .race_c p { font-size: 1rem; line-height: 1.8; color: var(--muted); }
    .race_c .quote { font-family: var(--FD); font-style: italic; font-size: 1.3rem; color: var(--slt); padding: 30px 0; }

    .repro_g { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px; }
    .repro_c { background: white; border-radius: var(--r); overflow: hidden; box-shadow: 0 4px 16px rgba(27,58,75,.06); transition: transform .3s; }
    .repro_c:hover { transform: translateY(-4px); }
    .repro_c img { height: 320px; }
    .repro_c .info { padding: 24px; }
    .repro_c .info .name { font-family: var(--FD); font-size: 1.1rem; color: var(--slt); }
    .repro_c .info .role { font-size: .85rem; color: var(--muted); }
    .repro_c .info .desc { font-size: .9rem; padding: 0 !important; margin-top: 8px; }

    .gal_g { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; }
    .gal_g img { height: 260px; border-radius: var(--r); }

    .tem_g { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px,1fr)); gap: 24px; }
    .tem_c { background: white; border-radius: var(--r); padding: 28px; box-shadow: 0 4px 12px rgba(27,58,75,.04); }
    .tem_c .txt { font-style: italic; font-size: .9rem; line-height: 1.7; color: var(--muted); }
    .tem_c .auth { display: flex; align-items: center; gap: 12px; margin-top: 16px; }
    .tem_c .auth img { width: 40px; height: 40px; border-radius: 50%; }
    .tem_c .auth .name { font-weight: 600; font-size: .85rem; }
    .tem_c .auth .chiot { font-size: .75rem; color: var(--muted); }

    .contact_g { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
    .contact_g .info h3 { font-family: var(--FD); font-size: 1.3rem; margin-bottom: 12px; }
    .contact_g .info p { font-size: .95rem; color: var(--muted); line-height: 1.7; }
    .contact_g .info .phone { font-size: 1.4rem; font-weight: 700; color: var(--slt); margin: 16px 0; letter-spacing: .5px; }
    .contact_g .info .dtl { margin-top: 20px; }
    .contact_g .info .dtl > div { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid rgba(27,58,75,.06); }
    .contact_g .info .dtl > div:last-child { border-bottom: none; }
    .contact_g .info .dtl .lb { color: var(--muted); min-width: 80px; font-size: .85rem; }
    .contact_g .info .dtl .vl { font-weight: 500; }
    .contact_card { background: white; border-radius: var(--r); padding: 36px; box-shadow: 0 8px 24px rgba(27,58,75,.04); }
    .contact_card h3 { font-family: var(--FD); font-size: 1.3rem; margin-bottom: 16px; }
    .contact_card p { font-size: .9rem; color: var(--muted); line-height: 1.7; margin-bottom: 20px; }

    footer { background: var(--slt); color: rgba(255,255,255,.6); padding: 40px 0; text-align: center; }
    footer p { font-size: .85rem; line-height: 1.6; }
    footer a { color: var(--snd); text-decoration: underline; }

    @media(max-width:768px){
      .hero .container { grid-template-columns: 1fr; gap: 32px; }
      .hero_txt h1 { font-size: 2.2rem; }
      .hero_stats { grid-template-columns: 1fr; }
      .about_g { grid-template-columns: 1fr; gap: 32px; }
      .contact_g { grid-template-columns: 1fr; gap: 32px; }
      .gal_g { grid-template-columns: 1fr 1fr; }
      .nav_rub { display: none; }
      section { padding: 64px 0; }
      .sec_title { font-size: 1.8rem; }
    }
  </style>
</head>
<body>
<nav>
  <div class="container">
    <span class="nav_logo">{{ elevage.nom }}</span>
    <div class="nav_rub">
      <a href="#about">À propos</a>
      <a href="#race">La race</a>
      {% if photos.galerie %}<a href="#galerie">Galerie</a>{% endif %}
      <a href="#contact">Contact</a>
    </div>
  </div>
</nav>

<section class="hero">
  <div class="container">
    <div class="hero_txt">
      <span class="race_tag">{{ elevage.race }}</span>
      <h1>{{ elevage.nom }}</h1>
      <p class="loc">{% if elevage.code_postal %}{{ elevage.code_postal }} — {% endif %}{{ elevage.departement or "France" }}</p>
      <p>{{ elevage.description_hero or ("Élevage " + elevage.race) }}</p>
      <div class="hero_btns">
        <a href="#contact" class="btn btn_primary">Me contacter</a>
        <a href="#about" class="btn ghost_btn">Découvrir</a>
      </div>
      <div class="hero_stats">
        <div><div class="val">{{ elevage.race }}</div><div class="lbl">Race</div></div>
        {% if elevage.since %}<div><div class="val">{{ elevage.since }}</div><div class="lbl">Depuis</div></div>{% endif %}
        <div><div class="val">{{ elevage.departement or "France" }}</div><div class="lbl">Localisation</div></div>
      </div>
    </div>
    <div class="hero_img reveal">
      <img src="{% if photos.hero %}{{ photos.hero }}{% else %}https://images.pexels.com/photos/1108099/pexels-photo-1108099.jpeg{% endif %}" alt="{{ elevage.nom }}">
    </div>
  </div>
</section>

{% if elevage.description_about %}
<section id="about">
  <div class="container">
    <div class="about_g">
      <div class="reveal">
        <h2 class="sec_title">À propos</h2>
        {% for paragraph in elevage.description_about.split('\n') %}
          {% if paragraph.strip() %}<p>{{ paragraph.strip() }}</p>{% endif %}
        {% endfor %}
      </div>
      {% if photos.about_1 %}
      <div class="about_img reveal">
        <img src="{{ photos.about_1 }}" alt="{{ elevage.nom }}" style="height:480px">
      </div>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

<section id="race" class="alt_bg">
  <div class="container">
    <div class="race_c reveal">
      <h2 class="sec_title">Le {{ elevage.race }}</h2>
      <p>Le {{ elevage.race }} est une race de chien reconnue pour ses qualités et son caractère unique. Chaque chien est le fruit d'une sélection rigoureuse et d'un travail quotidien pour préserver les meilleures caractéristiques de la race.</p>
      <br>
      <p>Pour en savoir plus sur cette magnifique race et découvrir ses particularités, n'hésitez pas à contacter directement l'élevage. Un véritable passionné saura vous guider vers le compagnon qui vous correspond.</p>
    </div>
  </div>
</section>

{% if photos.galerie %}
<section id="galerie">
  <div class="container">
    <div style="text-align:center;">
      <h2 class="sec_title">Galerie photos</h2>
      <p class="sec_sub" style="margin:0 auto 48px;">Quelques instants de vie de l'élevage</p>
    </div>
    <div class="gal_g">
      {% for url in photos.galerie %}
      <img src="{{ url }}" alt="{{ elevage.race }}" class="reveal" loading="lazy">
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<section id="contact" class="alt_bg">
  <div class="container">
    <div class="contact_g">
      <div class="info reveal">
        <h2 class="sec_title">Contact</h2>
        <p>{{ elevage.description_hero or ("Élevage " + elevage.race + ". N'hésitez pas à nous contacter pour toute information.") }}</p>
        <div class="phone">📞 {{ elevage.telephone }}</div>
        <div class="dtl">
          <div><span class="lb">📍 Lieu</span><span class="vl">{{ elevage.departement or "France" }}</span></div>
          <div><span class="lb">🐕 Race</span><span class="vl">{{ elevage.race }}</span></div>
          {% if elevage.siren %}<div><span class="lb">🆔 SIREN</span><span class="vl">{{ elevage.siren }}</span></div>{% endif %}
          {% if elevage.code_postal %}<div><span class="lb">📮 Code</span><span class="vl">{{ elevage.code_postal }}</span></div>{% endif %}
        </div>
      </div>
      <div class="contact_card reveal">
        <h3>{{ elevage.nom }}</h3>
        <p>Élevage {{ elevage.race }}{% if elevage.departement %} — {{ elevage.departement }}{% endif %}.</p>
        <a href="tel:{{ elevage.telephone }}" class="btn btn_primary" style="display:block;text-align:center;">📞 {{ elevage.telephone }}</a>
      </div>
    </div>
  </div>
</section>

<footer>
  <p>© 2026 — {{ elevage.nom }} — {{ elevage.race }}</p>
  {% if elevage.siren %}<p>SIREN {{ elevage.siren }}</p>{% endif %}
  <p style="margin-top:4px;font-size:.75rem;">{{ elevage.departement or "France" }}</p>
</footer>

<script>
  const observer = new IntersectionObserver(e => { e.forEach(e => { if(e.isIntersecting) e.target.classList.add('on'); }); }, { threshold: .15 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
</body>
</html>
