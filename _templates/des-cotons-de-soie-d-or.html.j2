{#- template: des-cotons-de-soie-d-or -#}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- MODIFIER : titre SEO -->
  <title>{{ elevage.nom }} — Élevage {{ elevage.race }} | {{ elevage.departement }}</title>
  <meta name="description" content="{{ elevage.description_seo }}">

  <!-- Open Graph -->
  <meta property="og:type"        content="website">
  <meta property="og:url"         content="https://des-cotons-de-soie-dor.netlify.app/">
  <meta property="og:title"       content="{{ elevage.nom }} — {{ elevage.race }}, {{ elevage.departement }}">
  <meta property="og:description" content="{{ elevage.description_seo }}">
  <meta property="og:image"       content="{{ photos.hero }}">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- MODIFIER : polices -->
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Josefin+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "name": "Des Cotons de Soie d'Or",
        "description": "Élevage professionnel de Loulou de Poméranie (Spitz nain) à Lys-lez-Lannoy, dans le Nord",
        "telephone": "+33659588632",
        "identifier": "987570942",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "7 bis rue Catinat",
          "addressLocality": "Lys-lez-Lannoy",
          "postalCode": "59390",
          "addressRegion": "Nord",
          "addressCountry": "FR"
        },
        "hasCredential": "Certificat de capacité 2024/1730-afb0"
      },
      { "@type": "AnimalShelter", "name": "Des Cotons de Soie d'Or — Loulou de Poméranie" }
    ]
  }
  </script>

  <style>
    /* ==============================================
       VARIABLES CSS — Des Cotons de Soie d'Or
       Palette inspirée du pelage orange/sable/crème
       du Loulou de Poméranie
       ============================================== */
    :root {
      --amb:  #B86820;   /* ambre orangé profond */
      --gld:  #D4962A;   /* or chaud */
      --sbl:  #7A5814;   /* sable foncé */
      --crm:  #FDF2E3;   /* crème ivoire */
      --bg:   #FEF8F0;   /* fond blanc crème orangé */
      --stn:  #9A8060;   /* pierre chaude */
      --txt:  #2A1A0A;   /* texte brun profond */
      --FD:   'Cormorant Garamond', serif;   /* police titres */
      --FN:   'Josefin Sans', sans-serif;    /* police corps */
      --nav:  72px;
      --r:    8px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--FN); background: var(--bg); color: var(--txt); overflow-x: hidden; }
    img { display: block; width: 100%; height: 100%; object-fit: cover; }
    a { color: inherit; text-decoration: none; }
    ul { list-style: none; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; }

    /* ---- SCROLL REVEAL ---- */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity .7s ease, transform .7s ease; }
    .reveal.on { opacity: 1; transform: none; }

    /* ---- BOUTONS ---- */
    .btn {
      display: inline-block; padding: .78rem 2.2rem;
      font-family: var(--FN); font-weight: 700; font-size: .75rem;
      letter-spacing: .16em; text-transform: uppercase;
      transition: background .2s, color .2s, transform .15s, box-shadow .2s;
      border-radius: 2px;
    }
    .btn--primary { background: var(--amb); color: #fff; }
    .btn--primary:hover { background: #9a5416; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(184,104,32,.38); }
    .btn--dark { background: var(--sbl); color: #fff; }
    .btn--dark:hover { background: #5a3e0c; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(122,88,20,.32); }
    .btn--outline { background: transparent; color: var(--sbl); border: 1.5px solid var(--sbl); }
    .btn--outline:hover { background: var(--sbl); color: #fff; transform: translateY(-2px); }
    .btn--white { background: rgba(255,255,255,.14); color: #fff; border: 1px solid rgba(255,255,255,.5); backdrop-filter: blur(8px); }
    .btn--white:hover { background: rgba(255,255,255,.26); transform: translateY(-2px); }
    .btn--gold { background: var(--gld); color: #fff; }
    .btn--gold:hover { background: #b87e20; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(212,150,42,.4); }

    /* ---- NAV ---- */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: var(--nav);
      background: rgba(254,248,240,.97);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(184,104,32,.1);
      display: flex; align-items: center; padding: 0 4vw;
      transition: box-shadow .3s;
    }
    nav.scrolled { box-shadow: 0 2px 28px rgba(184,104,32,.1); }
    .nav__logo {
      font-family: var(--FD); font-size: 1.22rem; font-weight: 600; font-style: italic;
      color: var(--sbl); line-height: 1.1; margin-right: auto; letter-spacing: .02em;
    }
    .nav__logo span { display: block; font-family: var(--FN); font-style: normal; font-size: .56rem; font-weight: 600; color: var(--stn); letter-spacing: .24em; text-transform: uppercase; margin-top: .12rem; }
    .nav__links { display: flex; align-items: center; gap: 2.2rem; }
    .nav__links > li > a {
      font-size: .7rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
      color: var(--txt); transition: color .2s; position: relative;
    }
    .nav__links > li > a::after { content: ''; position: absolute; bottom: -3px; left: 0; width: 0; height: 1px; background: var(--amb); transition: width .2s; }
    .nav__links > li > a:hover { color: var(--amb); }
    .nav__links > li > a:hover::after { width: 100%; }
    .nav__cta { margin-left: 1.4rem; }

    .nav__drop { position: relative; }
    .nav__drop > a::after { display: none !important; }
    .nav__drop > a .arr { font-size: .52rem; margin-left: .25rem; display: inline-block; transition: transform .2s; }
    .nav__drop:hover > a .arr { transform: rotate(180deg); }
    .drop__menu {
      position: absolute; top: calc(100% + 14px); left: 50%;
      transform: translateX(-50%) translateY(6px);
      background: #fff; border: 1px solid rgba(184,104,32,.1);
      border-radius: var(--r); padding: .5rem 0;
      box-shadow: 0 12px 44px rgba(184,104,32,.12);
      min-width: 200px; opacity: 0; visibility: hidden; pointer-events: none;
      transition: opacity .2s, visibility .2s, transform .2s;
    }
    .nav__drop:hover .drop__menu { opacity: 1; visibility: visible; pointer-events: auto; transform: translateX(-50%) translateY(0); }
    .drop__menu::before { content: ''; position: absolute; top: -14px; left: 0; right: 0; height: 14px; }
    .drop__menu a { display: block; padding: .55rem 1.4rem; font-size: .68rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--txt); transition: background .15s, color .15s; }
    .drop__menu a:hover { background: var(--crm); color: var(--amb); }

    .nav__burger { display: none; flex-direction: column; gap: 5px; padding: .5rem; }
    .nav__burger span { width: 22px; height: 1.5px; background: var(--txt); border-radius: 2px; transition: transform .25s, opacity .25s; }
    .nav__burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .nav__burger.open span:nth-child(2) { opacity: 0; }
    .nav__burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
    .nav__mobile {
      display: none; position: fixed; inset: 0; z-index: 90;
      background: var(--bg); padding: calc(var(--nav) + 1.5rem) 2rem 2rem;
      flex-direction: column; gap: .2rem; overflow-y: auto;
    }
    .nav__mobile.open { display: flex; }
    .nav__mobile a { font-size: .84rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--txt); padding: .8rem 0; border-bottom: 1px solid var(--crm); }
    .nav__mobile a:hover { color: var(--amb); }
    .nav__mobile .mob-sub { padding-left: 1.2rem; font-size: .76rem !important; color: var(--stn) !important; }

    /* ---- HERO ---- */
    .hero {
      position: relative; height: 100svh; min-height: 620px;
      display: flex; align-items: center; justify-content: center;
      margin-top: var(--nav); overflow: hidden;
    }
    .hero__bg {
      position: absolute; inset: 0;
      /* MODIFIER : remplacer par une photo de l'élevage */
      background: url('{{ photos.hero }}') center/cover no-repeat;
      transform: scale(1.07); transition: transform 12s ease;
    }
    .hero.loaded .hero__bg { transform: scale(1); }
    /* Overlay dégradé ambre chaud */
    .hero__over {
      position: absolute; inset: 0;
      background: linear-gradient(148deg,
        rgba(184,104,32,.18) 0%,
        rgba(122,88,20,.52) 55%,
        rgba(42,26,10,.82) 100%);
    }
    /* Grain texture subtil */
    .hero__grain {
      position: absolute; inset: 0; opacity: .04; pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }
    /* Ornement décoratif en coin */
    .hero__ornament {
      position: absolute; bottom: 0; left: 0; right: 0; height: 90px; pointer-events: none;
      background: linear-gradient(to top, var(--bg) 0%, transparent 100%);
    }
    .hero__content {
      position: relative; z-index: 1; color: #fff;
      text-align: center; padding: 0 1.5rem; max-width: 780px;
    }
    .hero__eyebrow {
      font-family: var(--FN); font-size: .66rem; font-weight: 600;
      letter-spacing: .3em; text-transform: uppercase;
      color: var(--gld); margin-bottom: 1.8rem;
      display: flex; align-items: center; justify-content: center; gap: 1.2rem;
    }
    .hero__eyebrow::before, .hero__eyebrow::after { content: ''; display: block; width: 44px; height: 1px; background: var(--gld); opacity: .65; }
    .hero__title {
      font-family: var(--FD); font-size: clamp(2.8rem, 7vw, 6.5rem);
      font-weight: 500; font-style: italic; line-height: 1.02;
      margin-bottom: 1.2rem; text-shadow: 0 2px 40px rgba(0,0,0,.25);
      letter-spacing: -.01em;
    }
    .hero__subtitle {
      font-family: var(--FN); font-size: .7rem; font-weight: 700;
      letter-spacing: .32em; text-transform: uppercase;
      color: rgba(255,255,255,.6); margin-bottom: 1.8rem;
    }
    .hero__sub {
      font-size: clamp(.88rem, 1.5vw, 1rem); font-weight: 300;
      color: rgba(255,255,255,.84); line-height: 1.82;
      max-width: 540px; margin: 0 auto 2.6rem;
    }
    .hero__btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .hero__scroll {
      position: absolute; bottom: 2.4rem; left: 50%; transform: translateX(-50%);
      color: rgba(255,255,255,.45); font-size: .6rem; letter-spacing: .18em; text-transform: uppercase;
      display: flex; flex-direction: column; align-items: center; gap: .5rem; z-index: 1;
    }
    .hero__scroll::after {
      content: ''; width: 1px; height: 38px; background: rgba(255,255,255,.3);
      animation: scrollLine 2.2s ease-in-out infinite;
    }
    @keyframes scrollLine { 0%,100%{opacity:0;transform:scaleY(0);transform-origin:top} 50%{opacity:1;transform:scaleY(1)} }

    /* ---- BANDEAU INFOS ---- */
    .bandeau {
      background: var(--sbl); color: rgba(255,255,255,.72);
      display: grid; grid-template-columns: repeat(4,1fr);
      border-bottom: 1px solid rgba(255,255,255,.06);
    }
    .ban__item {
      padding: 1.7rem 1rem; text-align: center;
      border-right: 1px solid rgba(255,255,255,.08);
    }
    .ban__item:last-child { border-right: none; }
    .ban__n { font-family: var(--FD); font-size: 1.55rem; font-style: italic; color: var(--gld); line-height: 1; margin-bottom: .3rem; }
    .ban__l { font-family: var(--FN); font-size: .58rem; font-weight: 600; letter-spacing: .16em; text-transform: uppercase; opacity: .5; }

    /* ---- SECTIONS GÉNÉRIQUES ---- */
    section { padding: 6.5rem 4vw; }
    .sec__head { text-align: center; margin-bottom: 3.8rem; }
    .sec__eyebrow {
      display: inline-flex; align-items: center; gap: .8rem;
      font-family: var(--FN); font-size: .6rem; font-weight: 700;
      letter-spacing: .24em; text-transform: uppercase; color: var(--amb);
      margin-bottom: .9rem;
    }
    .sec__eyebrow::before, .sec__eyebrow::after { content: ''; display: block; width: 24px; height: 1px; background: var(--amb); opacity: .5; }
    .sec__title { font-family: var(--FD); font-size: clamp(1.9rem, 3.8vw, 3.1rem); font-weight: 500; color: var(--sbl); line-height: 1.1; }
    .sec__title em { font-style: italic; color: var(--amb); }
    .sec__sub { max-width: 560px; margin: 1rem auto 0; font-family: var(--FN); font-size: .92rem; color: #888; line-height: 1.85; font-weight: 300; }

    /* ---- ABOUT ---- */
    .about { background: var(--bg); }
    .about__grid { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .about__imgs { position: relative; height: 540px; }
    .about__main {
      position: absolute; left: 0; top: 0; width: 70%; height: 80%;
      border-radius: var(--r); overflow: hidden;
      box-shadow: 0 24px 70px rgba(122,88,20,.2);
    }
    .about__accent {
      position: absolute; right: 0; bottom: 0; width: 50%; height: 52%;
      border-radius: var(--r); overflow: hidden;
      box-shadow: 0 12px 40px rgba(0,0,0,.12);
      border: 4px solid var(--bg);
    }
    .about__medal {
      position: absolute; right: 5%; top: 30%; z-index: 2;
      width: 82px; height: 82px; border-radius: 50%;
      background: linear-gradient(135deg, var(--gld), var(--amb));
      color: #fff;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      box-shadow: 0 8px 32px rgba(212,150,42,.5);
      font-family: var(--FD); font-size: .82rem; font-style: italic; font-weight: 600; text-align: center; line-height: 1.2;
    }
    .about__medal small { font-family: var(--FN); font-size: .42rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; margin-top: .2rem; opacity: .8; }
    .about__text {}
    .about__text h2 { font-family: var(--FD); font-size: clamp(1.7rem, 2.8vw, 2.5rem); font-weight: 500; margin-bottom: 1.2rem; line-height: 1.15; }
    .about__text h2 em { font-style: italic; color: var(--amb); }
    .about__text p { font-family: var(--FN); font-weight: 300; color: #666; line-height: 1.88; margin-bottom: 1rem; font-size: .94rem; }
    .about__list { margin: 1.6rem 0; display: flex; flex-direction: column; gap: .7rem; }
    .about__li { display: flex; align-items: flex-start; gap: .9rem; font-family: var(--FN); font-size: .9rem; color: #666; line-height: 1.6; font-weight: 300; }
    .about__li-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gld); flex-shrink: 0; margin-top: .55rem; }
    .about__li strong { color: var(--sbl); font-weight: 600; }

    /* ---- LA RACE ---- */
    .race { background: var(--crm); }
    .race__wrap { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .race__img { position: relative; height: 540px; border-radius: var(--r); overflow: hidden; box-shadow: 0 24px 64px rgba(122,88,20,.18); }
    .race__img img { position: absolute; inset: 0; height: 100%; }
    .race__content {}
    .race__content p { font-family: var(--FN); font-weight: 300; font-size: .94rem; line-height: 1.88; color: #666; margin-bottom: 1rem; }
    .race__truffe {
      display: flex; align-items: flex-start; gap: .9rem;
      background: var(--sbl); color: rgba(255,255,255,.82);
      border-radius: var(--r); padding: 1.3rem 1.5rem;
      margin: 1.6rem 0; font-family: var(--FN); font-size: .85rem; line-height: 1.72; font-weight: 300;
    }
    .race__truffe-ico { font-size: 1.4rem; flex-shrink: 0; margin-top: .1rem; }
    .race__truffe strong { color: var(--gld); font-weight: 600; display: block; margin-bottom: .2rem; font-size: .88rem; }
    .race__specs { display: grid; grid-template-columns: 1fr 1fr; gap: .7rem; margin-bottom: 2rem; }
    .race__spec { background: #fff; border-radius: var(--r); padding: .85rem 1rem; border-left: 2px solid var(--gld); }
    .race__spec strong { display: block; font-family: var(--FN); font-size: .56rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: #bbb; margin-bottom: .25rem; }
    .race__spec span { font-family: var(--FD); font-size: .95rem; font-weight: 500; font-style: italic; color: var(--sbl); }

    /* ---- SECTION COULEURS ---- */
    .couleurs { background: var(--bg); }
    .couleurs__intro { max-width: 680px; margin: 0 auto 3.5rem; text-align: center; }
    .couleurs__intro p { font-family: var(--FN); font-weight: 300; color: #888; line-height: 1.85; font-size: .94rem; }
    .couleurs__grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.4rem; }
    .couleur__card {
      border-radius: var(--r); overflow: hidden;
      box-shadow: 0 2px 18px rgba(122,88,20,.1);
      transition: transform .3s, box-shadow .3s;
    }
    .couleur__card:hover { transform: translateY(-4px); box-shadow: 0 14px 44px rgba(122,88,20,.18); }
    .couleur__swatch { height: 110px; position: relative; }
    .couleur__swatch::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,.18));
    }
    .couleur__body { background: #fff; padding: 1rem 1.1rem; }
    .couleur__name { font-family: var(--FD); font-size: 1.1rem; font-style: italic; font-weight: 500; color: var(--sbl); margin-bottom: .2rem; }
    .couleur__desc { font-family: var(--FN); font-size: .72rem; font-weight: 300; color: #999; line-height: 1.6; }
    /* Swatches couleurs */
    .sw-orange   { background: linear-gradient(135deg, #D4622A 0%, #E87830 50%, #C05018 100%); }
    .sw-sable    { background: linear-gradient(135deg, #C9942A 0%, #E0AE50 50%, #A87E28 100%); }
    .sw-creme    { background: linear-gradient(135deg, #F0D8A8 0%, #FAF0D4 50%, #E8C880 100%); }
    .sw-fauve    { background: linear-gradient(135deg, #B85A18 0%, #D47030 50%, #904010 100%); }
    .sw-abricot  { background: linear-gradient(135deg, #E8A060 0%, #F4C080 50%, #D07840 100%); }
    .sw-blanc-creme { background: linear-gradient(135deg, #F8EED8 0%, #FEFAF0 50%, #F0E4C4 100%); }
    .couleurs__note {
      max-width: 760px; margin: 2.4rem auto 0;
      background: var(--crm); border-radius: var(--r); padding: 1.2rem 1.6rem;
      border-left: 3px solid var(--gld);
      font-family: var(--FN); font-size: .85rem; font-weight: 300; color: #888; line-height: 1.75;
    }
    .couleurs__note strong { color: var(--sbl); font-weight: 600; }

    /* ---- REPRODUCTEURS ---- */
    .repro { background: var(--crm); }
    .repro__grid { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fill, minmax(300px,1fr)); gap: 1.8rem; }
    .dog__card { border-radius: var(--r); overflow: hidden; box-shadow: 0 2px 20px rgba(122,88,20,.08); background: #fff; transition: transform .3s, box-shadow .3s; }
    .dog__card:hover { transform: translateY(-5px); box-shadow: 0 18px 54px rgba(122,88,20,.16); }
    .dog__img { height: 320px; overflow: hidden; position: relative; }
    .dog__img img { transition: transform .6s; }
    .dog__card:hover .dog__img img { transform: scale(1.06); }
    .dog__over {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(42,26,10,.78) 0%, transparent 55%);
    }
    .dog__name-wrap { position: absolute; bottom: 0; left: 0; right: 0; padding: 1.5rem 1.6rem; }
    .dog__name { font-family: var(--FD); font-size: 1.85rem; font-weight: 500; font-style: italic; color: #fff; line-height: 1; }
    .dog__sex-label { font-family: var(--FN); font-size: .58rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--gld); margin-top: .25rem; }
    .dog__body { padding: 1.3rem 1.6rem; }
    .dog__tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: .9rem; }
    .dog__tag { background: var(--crm); border-radius: 3px; padding: .22rem .72rem; font-family: var(--FN); font-size: .62rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--sbl); }
    .dog__tag--gold { background: var(--gld); color: #fff; }
    .dog__desc { font-family: var(--FN); font-size: .87rem; font-weight: 300; color: #888; line-height: 1.78; }

    /* ---- GALERIE ---- */
    .galerie { background: var(--bg); }
    .gal__grid {
      max-width: 1180px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(3,1fr); gap: 8px;
    }
    .gi { overflow: hidden; border-radius: 6px; position: relative; cursor: pointer; }
    .gi img { height: 230px; transition: transform .55s; }
    .gi:nth-child(1), .gi:nth-child(5) { grid-row: span 2; }
    .gi:nth-child(1) img, .gi:nth-child(5) img { height: 100%; }
    .gi:hover img { transform: scale(1.07); }
    .gi__over { position: absolute; inset: 0; background: rgba(184,104,32,.38); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity .3s; }
    .gi:hover .gi__over { opacity: 1; }
    .gi__over span { color: #fff; font-family: var(--FD); font-size: 2rem; font-style: italic; }

    /* ---- LIGHTBOX ---- */
    #lb { display: none; position: fixed; inset: 0; z-index: 300; background: rgba(0,0,0,.95); align-items: center; justify-content: center; }
    #lb.open { display: flex; }
    #lb img { max-width: 90vw; max-height: 90vh; object-fit: contain; border-radius: 4px; }
    #lb-close { position: absolute; top: 1.2rem; right: 1.5rem; color: #fff; font-size: 2rem; cursor: pointer; opacity: .55; transition: opacity .2s; }
    #lb-close:hover { opacity: 1; }
    #lb-prev, #lb-next { position: absolute; top: 50%; transform: translateY(-50%); color: #fff; font-size: 2.4rem; padding: 1rem; opacity: .45; cursor: pointer; transition: opacity .2s; }
    #lb-prev:hover, #lb-next:hover { opacity: 1; }
    #lb-prev { left: 1rem; } #lb-next { right: 1rem; }

    /* ---- TEMOIGNAGES ---- */
    .temoignages { background: var(--crm); }
    .temo__grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(3,1fr); gap: 1.6rem; }
    .temo { background: var(--bg); border-radius: var(--r); padding: 1.9rem; box-shadow: 0 2px 18px rgba(122,88,20,.07); position: relative; }
    .temo__quote { font-family: var(--FD); font-size: 4.5rem; font-style: italic; color: var(--gld); opacity: .18; position: absolute; top: .3rem; left: 1.2rem; line-height: 1; }
    .temo__stars { color: var(--gld); font-size: .9rem; margin-bottom: 1rem; letter-spacing: .06em; }
    .temo__text { font-family: var(--FN); font-size: .88rem; font-weight: 300; line-height: 1.85; color: #666; margin-bottom: 1.4rem; font-style: italic; position: relative; z-index: 1; }
    .temo__author { display: flex; align-items: center; gap: .8rem; }
    .temo__av { width: 38px; height: 38px; border-radius: 50%; overflow: hidden; background: var(--crm); flex-shrink: 0; }
    .temo__name { font-family: var(--FN); font-weight: 700; font-size: .83rem; }
    .temo__dog { font-size: .7rem; color: #bbb; }

    /* ---- CONTACT ---- */
    .contact { background: var(--bg); }
    .contact__wrap { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.4fr; gap: 5rem; align-items: start; }
    .contact__info h3 { font-family: var(--FD); font-size: 1.7rem; font-style: italic; font-weight: 500; margin-bottom: 1.5rem; line-height: 1.15; color: var(--sbl); }
    .cinfo { display: flex; flex-direction: column; gap: 1.1rem; margin-bottom: 2rem; }
    .cinfo__item { display: flex; align-items: flex-start; gap: .85rem; }
    .cinfo__ico { width: 38px; height: 38px; border-radius: 8px; background: var(--crm); display: flex; align-items: center; justify-content: center; font-size: .95rem; flex-shrink: 0; }
    .cinfo__label { font-family: var(--FN); font-size: .58rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: #ccc; margin-bottom: .12rem; }
    .cinfo__val { font-family: var(--FN); font-size: .92rem; font-weight: 600; }
    .cinfo__val a:hover { color: var(--amb); }
    .cinfo__sub { font-size: .77rem; font-weight: 300; color: #bbb; margin-top: .1rem; }
    .certif-badge {
      display: inline-flex; align-items: center; gap: .5rem;
      background: var(--sbl); color: rgba(255,255,255,.88); border-radius: 4px;
      padding: .5rem 1.1rem; font-family: var(--FN); font-size: .68rem; font-weight: 700;
      letter-spacing: .08em; text-transform: uppercase; margin-top: 1rem;
    }
    .certif-badge + .certif-badge { margin-top: .5rem; }
    .contact__form { background: var(--crm); border-radius: var(--r); padding: 2.5rem; }
    .form__title { font-family: var(--FD); font-size: 1.45rem; font-style: italic; font-weight: 500; margin-bottom: .4rem; color: var(--sbl); }
    .form__sub { font-family: var(--FN); font-size: .83rem; font-weight: 300; color: #aaa; margin-bottom: 1.8rem; line-height: 1.65; }
    .form__section { font-family: var(--FN); font-size: .58rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--stn); margin: 1.4rem 0 .8rem; padding-bottom: .4rem; border-bottom: 1px solid rgba(122,88,20,.1); }
    .form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form__group { display: flex; flex-direction: column; gap: .32rem; margin-bottom: .9rem; }
    .form__group label { font-family: var(--FN); font-size: .66rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--txt); }
    .form__group input, .form__group select, .form__group textarea {
      width: 100%; padding: .72rem .95rem;
      border: 1.5px solid rgba(122,88,20,.12); border-radius: var(--r);
      font-family: var(--FN); font-size: .88rem; font-weight: 300; color: var(--txt);
      background: #fff; outline: none; transition: border-color .2s;
    }
    .form__group input:focus, .form__group select:focus, .form__group textarea:focus { border-color: var(--amb); }
    .form__group textarea { resize: vertical; min-height: 110px; }
    .form__hint { font-size: .68rem; color: #ccc; margin-top: .16rem; }
    .form__submit { width: 100%; margin-top: .4rem; padding: .95rem; font-size: .8rem; }
    .form__rgpd { font-family: var(--FN); font-size: .68rem; font-weight: 300; color: #ccc; text-align: center; margin-top: .8rem; line-height: 1.55; }

    /* ---- CONDITIONS / FAQ ---- */
    .conditions { background: var(--crm); }
    .conditions__wrap { max-width: 760px; margin: 0 auto; }
    .acc { border-bottom: 1px solid rgba(122,88,20,.08); }
    .acc__q { width: 100%; text-align: left; padding: 1.15rem 0; font-family: var(--FN); font-weight: 700; font-size: .9rem; letter-spacing: .02em; color: var(--txt); display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
    .acc__q .arr { font-size: .75rem; color: var(--amb); transition: transform .3s; flex-shrink: 0; }
    .acc__q.open .arr { transform: rotate(180deg); }
    .acc__a { display: none; padding-bottom: 1.15rem; font-family: var(--FN); font-size: .88rem; font-weight: 300; color: #777; line-height: 1.85; }
    .acc__a.open { display: block; }
    .acc__a ul { margin: .5rem 0 .5rem 1.2rem; list-style: disc; }
    .acc__a ul li { margin-bottom: .3rem; }

    /* ---- FOOTER ---- */
    footer { background: var(--sbl); color: rgba(255,255,255,.52); padding: 4.5rem 4vw 2.2rem; }
    .footer__wrap { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1.8fr 1fr 1fr; gap: 3rem; }
    .footer__logo { font-family: var(--FD); font-size: 1.3rem; font-style: italic; font-weight: 500; color: #fff; letter-spacing: .02em; margin-bottom: .5rem; }
    .footer__logo span { display: block; font-family: var(--FN); font-style: normal; font-size: .56rem; letter-spacing: .22em; text-transform: uppercase; color: rgba(255,255,255,.3); margin-top: .2rem; }
    footer p { font-family: var(--FN); font-size: .8rem; font-weight: 300; line-height: 1.75; margin-bottom: .3rem; }
    .footer__col h4 { font-family: var(--FN); font-size: .58rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: rgba(255,255,255,.82); margin-bottom: 1rem; }
    .footer__col a { display: block; font-family: var(--FN); font-size: .8rem; font-weight: 300; margin-bottom: .38rem; transition: color .2s; }
    .footer__col a:hover { color: #fff; }
    .footer__bottom { max-width: 1200px; margin: 2rem auto 0; padding-top: 1.4rem; border-top: 1px solid rgba(255,255,255,.08); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: .5rem; }
    .footer__bottom p { font-size: .72rem; margin: 0; }
    .footer__bottom a { color: var(--gld); }
    .footer__bottom a:hover { color: #fff; }

    /* ---- RESPONSIVE ---- */
    @media (max-width: 1024px) {
      .about__grid, .race__wrap, .contact__wrap { gap: 3rem; }
    }
    @media (max-width: 960px) {
      .nav__links, .nav__cta { display: none; }
      .nav__burger { display: flex; }
      .about__grid, .race__wrap, .contact__wrap, .footer__wrap { grid-template-columns: 1fr; }
      .about__imgs { height: 360px; }
      .race__img { height: 340px; }
      .temo__grid { grid-template-columns: 1fr; }
      .bandeau { grid-template-columns: repeat(2,1fr); }
      .ban__item:nth-child(2) { border-right: none; }
      .ban__item:nth-child(1), .ban__item:nth-child(2) { border-bottom: 1px solid rgba(255,255,255,.08); }
      .couleurs__grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 600px) {
      section { padding: 4rem 1.2rem; }
      .gal__grid { grid-template-columns: 1fr 1fr; }
      .gi:nth-child(1), .gi:nth-child(5) { grid-row: span 1; }
      .gi:nth-child(1) img, .gi:nth-child(5) img { height: 230px; }
      .form__row { grid-template-columns: 1fr; }
      .hero__btns { flex-direction: column; align-items: center; }
      .race__specs { grid-template-columns: 1fr; }
      .couleurs__grid { grid-template-columns: repeat(2, 1fr); }
      .repro__grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
