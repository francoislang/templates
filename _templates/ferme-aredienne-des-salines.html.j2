{#- template: ferme-aredienne-des-salines -#}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- MODIFIER : titre SEO -->
  <title>{{ elevage.nom }} — Élevage {{ elevage.race }} | {{ elevage.departement }}</title>
  <meta name="description" content="{{ elevage.description_seo }}">

  <!-- Open Graph -->
  <meta property="og:type"        content="website">
  <!-- MODIFIER : URL définitive -->
  <meta property="og:url"         content="https://www.ferme-aredienne-des-salines.fr/">
  <meta property="og:title"       content="{{ elevage.nom }} — {{ elevage.race }}, {{ elevage.departement }}">
  <meta property="og:description" content="{{ elevage.description_seo }}">
  <!-- REMPLACER : photo hero pour partage réseaux sociaux -->
  <meta property="og:image"       content="photo-west-highland/alexandru-silitra-Xhjj_P4GZjA-unsplash.jpg">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- MODIFIER : polices -->
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "name": "La Ferme Arédienne des Salines",
        "description": "Élevage familial de West Highland White Terrier à Saint-Yrieix-la-Perche",
        "telephone": "+33652611550",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "20 bis rue des Salines",
          "addressLocality": "Saint-Yrieix-la-Perche",
          "postalCode": "87500",
          "addressRegion": "Haute-Vienne",
          "addressCountry": "FR"
        },
        "taxID": "{{ elevage.siren }}",
        "openingHoursSpecification": { "@type": "OpeningHoursSpecification", "description": "Sur appel téléphonique préalable" }
      },
      { "@type": "AnimalShelter", "name": "La Ferme Arédienne des Salines — Westies" }
    ]
  }
  </script>

  <style>
    /* ==============================================
       VARIABLES CSS — adapter à chaque client ici
       ============================================== */
    :root {
      --grn:  #2E4D30;   /* MODIFIER : vert forêt principal */
      --wht:  #FFFFFF;   /* blanc pur */
      --stn:  #8B7D6B;   /* MODIFIER : pierre/tan chaud */
      --ivry: #FAF8F3;   /* MODIFIER : fond ivoire doux */
      --crm:  #F0EBE1;   /* MODIFIER : fond crème secondaire */
      --txt:  #1C2818;   /* MODIFIER : texte vert très foncé */
      --acc:  #C05B2A;   /* MODIFIER : accent terracotta */
      --FD:   'DM Serif Display', serif; /* MODIFIER : police titres */
      --FN:   'DM Sans', sans-serif;     /* MODIFIER : police corps */
      --ann:  0px;
      --nav:  70px;
      --r:    10px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--FN); background: var(--ivry); color: var(--txt); overflow-x: hidden; }
    img { display: block; width: 100%; height: 100%; object-fit: cover; }
    a { color: inherit; text-decoration: none; }
    ul { list-style: none; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; }

    /* ---- SCROLL REVEAL ---- */
    .reveal { opacity: 0; transform: translateY(24px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.on { opacity: 1; transform: none; }

    /* ---- BOUTONS ---- */
    .btn {
      display: inline-block; padding: .75rem 1.9rem; border-radius: 4px;
      font-family: var(--FN); font-weight: 600; font-size: .87rem;
      letter-spacing: .06em; text-transform: uppercase;
      transition: background .2s, color .2s, transform .15s, box-shadow .2s;
    }
    .btn--primary { background: var(--grn); color: #fff; }
    .btn--primary:hover { background: #1e3320; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(46,77,48,.35); }
    .btn--outline { background: transparent; color: var(--grn); border: 2px solid var(--grn); }
    .btn--outline:hover { background: var(--grn); color: #fff; transform: translateY(-2px); }
    .btn--acc { background: var(--acc); color: #fff; }
    .btn--acc:hover { background: #9e4820; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(192,91,42,.35); }
    .btn--white { background: rgba(255,255,255,.13); color: #fff; border: 2px solid rgba(255,255,255,.55); backdrop-filter: blur(6px); }
    .btn--white:hover { background: rgba(255,255,255,.22); transform: translateY(-2px); }

    /* ---- NAV ---- */
    nav {
      position: fixed; top: var(--ann); left: 0; right: 0; z-index: 100;
      height: var(--nav);
      background: rgba(250,248,243,.97);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(46,77,48,.12);
      display: flex; align-items: center; padding: 0 4vw;
      transition: top .3s, box-shadow .3s;
    }
    nav.scrolled { box-shadow: 0 4px 28px rgba(0,0,0,.08); }
    .nav__logo {
      font-family: var(--FD); font-size: 1.1rem;
      color: var(--grn); line-height: 1.15; margin-right: auto;
    }
    .nav__logo span { display: block; font-family: var(--FN); font-size: .63rem; font-weight: 600; color: var(--stn); letter-spacing: .2em; text-transform: uppercase; }
    .nav__links { display: flex; align-items: center; gap: 2rem; }
    .nav__links > li > a {
      font-size: .86rem; font-weight: 600; letter-spacing: .04em; color: var(--txt);
      transition: color .2s; position: relative;
    }
    .nav__links > li > a::after { content: ''; position: absolute; bottom: -3px; left: 0; width: 0; height: 2px; background: var(--grn); transition: width .2s; }
    .nav__links > li > a:hover { color: var(--grn); }
    .nav__links > li > a:hover::after { width: 100%; }
    .nav__cta { margin-left: 1.2rem; }

    .nav__drop { position: relative; }
    .nav__drop > a::after { display: none !important; }
    .nav__drop > a .arr { font-size: .62rem; margin-left: .25rem; display: inline-block; transition: transform .2s; }
    .nav__drop:hover > a .arr { transform: rotate(180deg); }
    .drop__menu {
      position: absolute; top: calc(100% + 12px); left: 50%;
      transform: translateX(-50%) translateY(6px);
      background: #fff; border: 1px solid rgba(46,77,48,.12);
      border-radius: 8px; padding: .5rem 0;
      box-shadow: 0 12px 40px rgba(0,0,0,.1);
      min-width: 180px; opacity: 0; visibility: hidden; pointer-events: none;
      transition: opacity .2s, visibility .2s, transform .2s;
    }
    .nav__drop:hover .drop__menu { opacity: 1; visibility: visible; pointer-events: auto; transform: translateX(-50%) translateY(0); }
    .drop__menu::before { content: ''; position: absolute; top: -14px; left: 0; right: 0; height: 14px; }
    .drop__menu a { display: block; padding: .52rem 1.2rem; font-size: .84rem; font-weight: 600; color: var(--txt); transition: background .15s, color .15s; }
    .drop__menu a:hover { background: var(--crm); color: var(--grn); }

    .nav__burger { display: none; flex-direction: column; gap: 5px; padding: .5rem; }
    .nav__burger span { width: 22px; height: 2px; background: var(--txt); border-radius: 2px; transition: transform .25s, opacity .25s; }
    .nav__burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav__burger.open span:nth-child(2) { opacity: 0; }
    .nav__burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .nav__mobile {
      display: none; position: fixed; inset: 0; z-index: 90;
      background: var(--ivry); padding: calc(var(--ann) + var(--nav) + 1.5rem) 2rem 2rem;
      flex-direction: column; gap: .2rem; overflow-y: auto;
    }
    .nav__mobile.open { display: flex; }
    .nav__mobile a { font-size: 1.12rem; font-weight: 600; color: var(--txt); padding: .72rem 0; border-bottom: 1px solid var(--crm); }
    .nav__mobile a:hover { color: var(--grn); }
    .nav__mobile .mob-sub { padding-left: 1.2rem; font-size: 1rem !important; color: var(--stn) !important; }

    /* ---- HERO ---- */
    .hero {
      position: relative; height: 100svh; min-height: 600px;
      display: flex; align-items: center; justify-content: center; text-align: center;
      margin-top: calc(var(--ann) + var(--nav)); overflow: hidden;
    }
    .hero__bg {
      position: absolute; inset: 0;
      /* REMPLACER : grande photo plein écran (Westie dans la nature, herbe, campagne) */
      background: url('photo-west-highland/alexandru-silitra-Xhjj_P4GZjA-unsplash.jpg') center/cover no-repeat;
      transform: scale(1.06); transition: transform 9s ease;
    }
    .hero.loaded .hero__bg { transform: scale(1); }
    .hero__over {
      position: absolute; inset: 0;
      background: linear-gradient(170deg, rgba(28,40,24,.35) 0%, rgba(46,77,48,.4) 50%, rgba(28,40,24,.75) 100%);
    }
    /* texture grain subtil */
    .hero__grain {
      position: absolute; inset: 0; opacity: .04; pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }
    .hero__content { position: relative; z-index: 1; color: #fff; padding: 0 1.5rem; max-width: 740px; }
    .hero__badge {
      display: inline-flex; align-items: center; gap: .6rem;
      background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.25);
      backdrop-filter: blur(8px); border-radius: 50px;
      font-size: .74rem; font-weight: 600; letter-spacing: .14em; text-transform: uppercase;
      padding: .45rem 1.1rem; color: rgba(255,255,255,.9); margin-bottom: 1.6rem;
    }
    .hero__badge::before { content: '🐾'; font-size: .8rem; }
    .hero__title {
      font-family: var(--FD); font-size: clamp(2.6rem, 6.5vw, 5.5rem);
      line-height: 1.08; margin-bottom: .8rem;
      text-shadow: 0 2px 28px rgba(0,0,0,.35);
    }
    .hero__title em { font-style: italic; }
    .hero__divider { display: flex; align-items: center; justify-content: center; gap: .8rem; margin-bottom: 1.2rem; opacity: .6; }
    .hero__divider::before, .hero__divider::after { content: ''; flex: 1; max-width: 60px; height: 1px; background: rgba(255,255,255,.5); }
    .hero__divider span { font-size: .7rem; letter-spacing: .2em; text-transform: uppercase; }
    .hero__sub { font-size: clamp(.9rem, 2vw, 1.08rem); font-weight: 300; opacity: .9; margin-bottom: 2.6rem; max-width: 520px; margin-left: auto; margin-right: auto; line-height: 1.7; }
    .hero__btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .hero__scroll {
      position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
      color: rgba(255,255,255,.6); font-size: .7rem; letter-spacing: .12em; text-transform: uppercase;
      display: flex; flex-direction: column; align-items: center; gap: .5rem;
    }
    .hero__scroll::after {
      content: ''; width: 1px; height: 36px; background: rgba(255,255,255,.4);
      animation: scrollLine 1.9s ease-in-out infinite;
    }
    @keyframes scrollLine { 0%,100%{opacity:0;transform:scaleY(0);transform-origin:top} 50%{opacity:1;transform:scaleY(1)} }

    /* ---- STATS ---- */
    .stats { background: var(--grn); color: #fff; display: grid; grid-template-columns: repeat(4,1fr); }
    .stat { padding: 1.8rem 1rem; border-right: 1px solid rgba(255,255,255,.12); text-align: center; }
    .stat:last-child { border-right: none; }
    .stat__n { font-family: var(--FD); font-size: 2.2rem; line-height: 1; color: #fff; }
    .stat__l { font-size: .75rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; opacity: .65; margin-top: .4rem; }

    /* ---- SECTIONS GÉNÉRIQUES ---- */
    section { padding: 6rem 4vw; }
    .sec__head { text-align: center; margin-bottom: 3.5rem; }
    .sec__eyebrow { font-size: .72rem; font-weight: 700; letter-spacing: .22em; text-transform: uppercase; color: var(--stn); margin-bottom: .8rem; }
    .sec__title { font-family: var(--FD); font-size: clamp(1.9rem, 4vw, 3rem); color: var(--txt); line-height: 1.15; }
    .sec__title em { font-style: italic; color: var(--grn); }
    .sec__sub { max-width: 560px; margin: 1rem auto 0; font-size: .97rem; color: #777; line-height: 1.78; }

    /* ---- ABOUT ---- */
    .about { background: var(--ivry); }
    .about__grid { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .about__imgs { position: relative; height: 500px; }
    .about__main {
      position: absolute; left: 0; top: 0; width: 73%; height: 82%;
      border-radius: var(--r); overflow: hidden;
      box-shadow: 0 20px 60px rgba(46,77,48,.2);
    }
    .about__accent {
      position: absolute; right: 0; bottom: 0; width: 47%; height: 50%;
      border-radius: var(--r); overflow: hidden;
      box-shadow: 0 10px 36px rgba(0,0,0,.13);
      border: 4px solid var(--ivry);
    }
    /* badge rustique */
    .about__stamp {
      position: absolute; right: 4%; top: 35%;
      width: 80px; height: 80px; border-radius: 50%;
      background: var(--acc); color: #fff;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      font-family: var(--FD); font-size: 1.1rem; line-height: 1;
      box-shadow: 0 8px 24px rgba(192,91,42,.4); z-index: 2;
    }
    .about__stamp small { font-family: var(--FN); font-size: .48rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; opacity: .85; margin-top: .2rem; }
    .about__text h2 { font-family: var(--FD); font-size: clamp(1.7rem, 3vw, 2.5rem); margin-bottom: 1.2rem; line-height: 1.2; }
    .about__text h2 em { font-style: italic; color: var(--grn); }
    .about__text p { color: #666; line-height: 1.82; margin-bottom: 1rem; font-size: .97rem; }
    .about__pillars { display: flex; flex-direction: column; gap: .7rem; margin: 1.6rem 0; }
    .pillar { display: flex; align-items: flex-start; gap: .9rem; }
    .pillar__ico { width: 36px; height: 36px; border-radius: 8px; background: var(--crm); display: flex; align-items: center; justify-content: center; font-size: .95rem; flex-shrink: 0; }
    .pillar__txt strong { display: block; font-size: .88rem; font-weight: 700; margin-bottom: .1rem; }
    .pillar__txt span { font-size: .82rem; color: #888; }

    /* ---- LA RACE ---- */
    .race { background: var(--grn); color: #fff; overflow: hidden; }
    .race__wrap { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 0; align-items: stretch; }
    .race__img { position: relative; min-height: 480px; }
    .race__img img { position: absolute; inset: 0; height: 100%; }
    .race__img::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to right, rgba(46,77,48,.3), transparent); }
    .race__content { padding: 4rem 3.5rem; display: flex; flex-direction: column; justify-content: center; }
    .race__content .sec__eyebrow { color: rgba(255,255,255,.6); text-align: left; }
    .race__content h2 { font-family: var(--FD); font-size: clamp(2rem, 3.5vw, 3rem); margin-bottom: 1.2rem; line-height: 1.1; }
    .race__content h2 em { font-style: italic; }
    .race__content p { font-size: .95rem; line-height: 1.8; opacity: .85; margin-bottom: 1rem; }
    .race__facts { display: grid; grid-template-columns: 1fr 1fr; gap: .7rem; margin: 1.8rem 0; }
    .race__fact { background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; padding: .8rem 1rem; }
    .race__fact strong { display: block; font-size: .72rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; opacity: .6; margin-bottom: .2rem; }
    .race__fact span { font-size: .9rem; font-weight: 600; }

    /* ---- REPRODUCTEURS ---- */
    .repro { background: var(--crm); }
    .repro__grid { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fill, minmax(270px,1fr)); gap: 1.8rem; }
    .dog__card { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,.06); transition: transform .3s, box-shadow .3s; }
    .dog__card:hover { transform: translateY(-5px); box-shadow: 0 16px 48px rgba(0,0,0,.12); }
    .dog__img { height: 230px; overflow: hidden; position: relative; }
    .dog__img img { transition: transform .6s; }
    .dog__card:hover .dog__img img { transform: scale(1.06); }
    .dog__sex { position: absolute; top: .8rem; right: .8rem; width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .85rem; }
    .dog__sex--f { background: rgba(255,200,210,.9); color: #7A1432; }
    .dog__sex--m { background: rgba(180,220,240,.9); color: #1a3c8b; }
    .dog__body { padding: 1.3rem 1.5rem; }
    .dog__name { font-family: var(--FD); font-size: 1.3rem; margin-bottom: .25rem; }
    .dog__born { font-size: .78rem; color: #bbb; margin-bottom: .8rem; }
    .dog__tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: .8rem; }
    .dog__tag { background: var(--crm); border-radius: 4px; padding: .24rem .75rem; font-size: .71rem; font-weight: 700; color: var(--grn); letter-spacing: .04em; }
    .dog__desc { font-size: .86rem; color: #888; line-height: 1.68; }

    /* ---- CHIOTS ---- */
    .chiots { background: var(--ivry); }
    .chiots__grid { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fill, minmax(240px,1fr)); gap: 1.6rem; }
    .pup { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,.06); transition: transform .3s, box-shadow .3s; }
    .pup:hover { transform: translateY(-4px); box-shadow: 0 14px 44px rgba(0,0,0,.11); }
    .pup__img { height: 200px; overflow: hidden; position: relative; }
    .pup__img img { transition: transform .6s; }
    .pup:hover .pup__img img { transform: scale(1.07); }
    .pup__badge {
      position: absolute; top: .8rem; left: .8rem;
      padding: .28rem .85rem; border-radius: 4px;
      font-size: .69rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase;
    }
    .badge--avail { background: #22c55e; color: #fff; }
    .badge--resa  { background: #f59e0b; color: #fff; }
    .badge--venir { background: var(--grn); color: #fff; }
    .pup__body { padding: 1.1rem 1.3rem; }
    .pup__name { font-family: var(--FD); font-size: 1.15rem; margin-bottom: .3rem; }
    .pup__meta { font-size: .79rem; color: #bbb; margin-bottom: .7rem; }
    .pup__price { font-size: 1.1rem; font-weight: 700; color: var(--grn); }
    .pup__price small { font-size: .74rem; font-weight: 400; color: #bbb; display: block; margin-top: .1rem; }
    .chiots__note { max-width: 1180px; margin: 2rem auto 0; padding: 1.5rem 2rem; background: var(--crm); border-left: 3px solid var(--grn); border-radius: 0 8px 8px 0; font-size: .9rem; color: #666; line-height: 1.7; }
    .chiots__cta { text-align: center; margin-top: 2rem; }

    /* ---- GALERIE ---- */
    .galerie { background: var(--crm); }
    .gal__grid {
      max-width: 1180px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(3,1fr); gap: 10px;
    }
    .gi { overflow: hidden; border-radius: 8px; position: relative; cursor: pointer; background: var(--ivry); }
    .gi img { height: 210px; transition: transform .5s; }
    .gi:nth-child(1), .gi:nth-child(5) { grid-row: span 2; }
    .gi:nth-child(1) img, .gi:nth-child(5) img { height: 100%; }
    .gi:hover img { transform: scale(1.07); }
    .gi__over { position: absolute; inset: 0; background: rgba(46,77,48,.45); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity .3s; }
    .gi:hover .gi__over { opacity: 1; }
    .gi__over span { color: #fff; font-size: 1.8rem; }

    /* ---- LIGHTBOX ---- */
    #lb { display: none; position: fixed; inset: 0; z-index: 300; background: rgba(0,0,0,.93); align-items: center; justify-content: center; }
    #lb.open { display: flex; }
    #lb img { max-width: 90vw; max-height: 90vh; object-fit: contain; border-radius: 6px; }
    #lb-close { position: absolute; top: 1.2rem; right: 1.5rem; color: #fff; font-size: 2rem; cursor: pointer; opacity: .7; }
    #lb-close:hover { opacity: 1; }
    #lb-prev, #lb-next { position: absolute; top: 50%; transform: translateY(-50%); color: #fff; font-size: 2.2rem; padding: 1rem; opacity: .6; cursor: pointer; }
    #lb-prev:hover, #lb-next:hover { opacity: 1; }
    #lb-prev { left: 1rem; } #lb-next { right: 1rem; }

    /* ---- TEMOIGNAGES ---- */
    .temoignages { background: var(--ivry); }
    .temo__grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(3,1fr); gap: 1.6rem; }
    .temo { background: #fff; border-radius: 12px; padding: 1.8rem; box-shadow: 0 4px 20px rgba(0,0,0,.06); border-top: 3px solid var(--grn); }
    .temo__stars { color: #F59E0B; font-size: .95rem; margin-bottom: 1rem; letter-spacing: .08em; }
    .temo__text { font-size: .91rem; line-height: 1.8; color: #555; margin-bottom: 1.4rem; font-style: italic; }
    .temo__author { display: flex; align-items: center; gap: .8rem; }
    .temo__av { width: 38px; height: 38px; border-radius: 50%; overflow: hidden; flex-shrink: 0; background: var(--crm); }
    .temo__name { font-weight: 700; font-size: .86rem; }
    .temo__dog { font-size: .74rem; color: #aaa; }

    /* ---- CONTACT ---- */
    .contact { background: var(--crm); }
    .contact__wrap { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.4fr; gap: 5rem; align-items: start; }
    .contact__info h3 { font-family: var(--FD); font-size: 1.6rem; margin-bottom: 1.5rem; line-height: 1.2; }
    .cinfo { display: flex; flex-direction: column; gap: 1.1rem; margin-bottom: 1.8rem; }
    .cinfo__item { display: flex; align-items: flex-start; gap: .85rem; }
    .cinfo__ico { width: 38px; height: 38px; border-radius: 8px; background: var(--ivry); display: flex; align-items: center; justify-content: center; font-size: .95rem; flex-shrink: 0; }
    .cinfo__label { font-size: .7rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: #bbb; margin-bottom: .12rem; }
    .cinfo__val { font-size: .93rem; font-weight: 600; }
    .cinfo__val a:hover { color: var(--grn); }
    .acaced {
      display: inline-flex; align-items: center; gap: .5rem;
      background: var(--grn); color: #fff; border-radius: 6px;
      padding: .5rem 1rem; font-size: .78rem; font-weight: 700;
      letter-spacing: .06em; text-transform: uppercase; margin-top: 1rem;
    }
    .contact__form { background: #fff; border-radius: 14px; padding: 2.4rem; box-shadow: 0 8px 40px rgba(0,0,0,.07); }
    .form__title { font-family: var(--FD); font-size: 1.35rem; margin-bottom: .4rem; }
    .form__sub { font-size: .86rem; color: #aaa; margin-bottom: 1.8rem; line-height: 1.6; }
    .form__section { font-size: .7rem; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; color: var(--stn); margin: 1.4rem 0 .8rem; padding-bottom: .4rem; border-bottom: 1px solid var(--crm); }
    .form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form__group { display: flex; flex-direction: column; gap: .35rem; margin-bottom: .9rem; }
    .form__group label { font-size: .78rem; font-weight: 700; color: var(--txt); letter-spacing: .03em; }
    .form__group input, .form__group select, .form__group textarea {
      width: 100%; padding: .72rem .95rem;
      border: 2px solid var(--crm); border-radius: 6px;
      font-family: var(--FN); font-size: .89rem; color: var(--txt);
      background: var(--ivry); outline: none; transition: border-color .2s, background .2s;
    }
    .form__group input:focus, .form__group select:focus, .form__group textarea:focus { border-color: var(--grn); background: #fff; }
    .form__group textarea { resize: vertical; min-height: 110px; }
    .form__hint { font-size: .72rem; color: #ccc; margin-top: .18rem; }
    .form__submit { width: 100%; margin-top: .4rem; padding: .88rem; font-size: .95rem; }
    .form__rgpd { font-size: .71rem; color: #ccc; text-align: center; margin-top: .8rem; line-height: 1.5; }

    /* ---- CONDITIONS ---- */
    .conditions { background: var(--ivry); }
    .conditions__wrap { max-width: 760px; margin: 0 auto; }
    .acc { border-bottom: 1px solid rgba(0,0,0,.07); }
    .acc__q { width: 100%; text-align: left; padding: 1.05rem 0; font-weight: 700; font-size: .95rem; color: var(--txt); display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
    .acc__q .arr { font-size: .8rem; color: var(--grn); transition: transform .3s; flex-shrink: 0; }
    .acc__q.open .arr { transform: rotate(180deg); }
    .acc__a { display: none; padding-bottom: 1.1rem; font-size: .9rem; color: #777; line-height: 1.8; }
    .acc__a.open { display: block; }
    .acc__a ul { margin: .5rem 0 .5rem 1.2rem; list-style: disc; }
    .acc__a ul li { margin-bottom: .3rem; }

    /* ---- FOOTER ---- */
    footer { background: var(--txt); color: rgba(255,255,255,.6); padding: 3.5rem 4vw 2rem; }
    .footer__wrap { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 3rem; }
    .footer__logo { font-family: var(--FD); font-size: 1.1rem; color: #fff; margin-bottom: .5rem; line-height: 1.2; }
    .footer__logo span { display: block; font-family: var(--FN); font-size: .62rem; letter-spacing: .2em; text-transform: uppercase; color: rgba(255,255,255,.45); margin-top: .2rem; }
    footer p { font-size: .82rem; line-height: 1.7; margin-bottom: .35rem; }
    .footer__col h4 { font-size: .72rem; font-weight: 700; letter-spacing: .17em; text-transform: uppercase; color: #fff; margin-bottom: 1rem; }
    .footer__col a { display: block; font-size: .82rem; margin-bottom: .38rem; transition: color .2s; }
    .footer__col a:hover { color: #fff; }
    .footer__bottom { max-width: 1200px; margin: 2rem auto 0; padding-top: 1.4rem; border-top: 1px solid rgba(255,255,255,.1); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: .5rem; }
    .footer__bottom p { font-size: .76rem; margin: 0; }
    .footer__bottom a { color: rgba(255,255,255,.5); }
    .footer__bottom a:hover { color: #fff; }

    /* ---- RESPONSIVE ---- */
    @media (max-width: 960px) {
      .nav__links, .nav__cta { display: none; }
      .nav__burger { display: flex; }
      .about__grid, .race__wrap, .contact__wrap, .footer__wrap { grid-template-columns: 1fr; }
      .about__imgs { height: 340px; }
      .race__img { min-height: 300px; }
      .race__content { padding: 2.5rem 2rem; }
      .temo__grid { grid-template-columns: 1fr; }
      .stats { grid-template-columns: repeat(2,1fr); }
      .stat:nth-child(2) { border-right: none; }
      .stat:nth-child(1), .stat:nth-child(2) { border-bottom: 1px solid rgba(255,255,255,.12); }
    }
    @media (max-width: 600px) {
      section { padding: 4rem 1.2rem; }
      .gal__grid { grid-template-columns: 1fr 1fr; }
      .gi:nth-child(1), .gi:nth-child(5) { grid-row: span 1; }
      .gi:nth-child(1) img, .gi:nth-child(5) img { height: 210px; }
      .form__row { grid-template-columns: 1fr; }
      .hero__btns { flex-direction: column; align-items: center; }
      .race__facts { grid-template-columns: 1fr; }
    }
  </style>
</head>
